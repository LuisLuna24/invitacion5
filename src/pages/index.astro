---
import Love from "../components/Love.astro";
import Welcome from "../components/Welcome.astro";
import Contador from "../components/Contador.astro";
import Layout from "../layouts/Layout.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
  <Welcome
    groomName="Federico"
    ;
    brideName="María"
    ;
    weddingDate="2023-12-15"
    ;
    weddingDateLabel="15 de diciembre de 2023"
    ;
    heroImage="/images/foto1.jpg"
    ;
    heroSubtitle="Nuestra historia de amor"
    ;
  />
  <Love
    message="¡Estamos emocionados de compartir este día tan especial con ustedes! Acompáñennos a celebrar el amor y la alegría en nuestra boda."
  />

  <Contador
    title="Cuenta Regresiva para Nuestra Boda"
    dateLabel="¡Faltan solo unos días para el gran día!"
    targetDate="2026-12-15T12:00:00"
    bgImage="/images/foto3.jpg"
    calendarLink="https://www.google.com/calendar/render?action=TEMPLATE&text=Boda+de+Federico+y+María&dates=20231215T000000Z/20231215T235959Z&details=¡Estamos+emocionados+de+compartir+este+día+tán+especial+con+ustedes!&location=Dirección+de+la+Boda&sf=true&output=xml"
    ;
  />
</Layout>
