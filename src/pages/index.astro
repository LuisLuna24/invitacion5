---
import Layout from "../layouts/Layout.astro";
import Welcome from "../components/Welcome.astro";
import Love from "../components/Love.astro";
import Acompanan from "../components/Acompanan.astro";
import Galeria from "../components/Galeria.astro";
import Lugares from "../components/Lugares.astro";
import Vestimenta from "../components/Vestimenta.astro";
import Regalos from "../components/Regalos.astro";
import Confirmacion from "../components/Confirmacion.astro";
---

<Layout
  title="Nuestra Boda | Jenny & Jona"
  description="¡Nos casamos! Acompáñanos a celebrar nuestra historia de amor este 28 de Noviembre de 2026."
>
  <!-- 1. Portada e Impacto con Contador Integrado -->
  <Welcome
    brideName="Jenny"
    groomName="Jona"
    weddingDateLabel="28 de Noviembre de 2026"
    targetDate="2026-11-28T17:00:00"
    heroImage="/images/foto1.webp"
    heroSubtitle="¡Nos Casamos!"
  />

  <!-- 2. Introducción Narrativa y Monograma -->
  <Love
    message="El amor es la fuerza que mueve al mundo, y hoy nos mueve a nosotros a dar este paso. Nos emociona infinitamente compartir el inicio de nuestro para siempre junto a las personas que más amamos."
  />

  <!-- 3. Quiénes nos acompañan (Padres y Padrinos) -->
  <Acompanan />

  <!-- 4. Galería de Fotos (Pinterest con Lazy Loading y Efecto Poético) -->
  <Galeria />

  <!-- 5. Ubicaciones y Horarios -->
  <Lugares />

  <!-- 6. Código de Vestimenta e Ilustración de Colores Reservados -->
  <Vestimenta />

  <!-- 7. Mesa de Regalos y Cuenta Bancaria con Copiar CLABE -->
  <Regalos />

  <!-- 8. Cierre y Confirmación por WhatsApp -->
  <Confirmacion
    phoneNumber="5610683465"
    deadlineLabel="1 de noviembre de 2026"
    coupleNames="Jenny & Jona"
  />
</Layout>
