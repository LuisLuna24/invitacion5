---
interface Person {
  nombre: string;
  finado?: boolean;
}

interface Props {
  brideParents?: Person[];
  groomParents?: Person[];
  godparents?: Person[];
}

const {
  brideParents = [
    { nombre: "Enrique Sánchez", finado: true },
    { nombre: "Graciela García" },
  ],
  groomParents = [
    { nombre: "Romualdo García" },
    { nombre: "Agustina de Jesús" },
  ],
  godparents = [{ nombre: "Sergio Partida" }, { nombre: "Lizbeth Morgado" }],
} = Astro.props;
---

<section
  class="w-full bg-surface-100 py-20 px-6 border-b border-primary-200/50 flex flex-col items-center"
>
  <div
    id="accompanied-section"
    class="max-w-md w-full mx-auto text-center opacity-0 translate-y-8 transition-all duration-1000 ease-out"
  >
    <!-- Icono de Corazón y Hojas -->
    <div class="mb-4 text-primary-500 flex justify-center">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1"
        stroke="currentColor"
        class="w-8 h-8"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z"
        ></path>
      </svg>
    </div>

    <!-- Título Principal -->
    <h2 class="font-serif text-3xl text-ink-800 font-light mb-4">
      Quiénes nos acompañan
    </h2>
    <p
      class="font-sans text-[10px] uppercase tracking-[0.2em] text-primary-600 font-semibold mb-10"
    >
      Con el amor de nuestras familias
    </p>

    <p
      class="font-sans text-xs md:text-sm text-ink-700 leading-relaxed italic mb-12 font-light"
    >
      "Con la bendición de Dios y el amor incondicional de nuestros padres,
      iniciamos este camino juntos. Su guía, paciencia y apoyo constante nos han
      formado y enseñado el verdadero significado del amor."
    </p>

    <!-- Columnas de Padres -->
    <div class="grid grid-cols-2 gap-6 text-center mb-12">
      <!-- Padres de la Novia -->
      <div
        class="flex flex-col items-center p-3 border-r border-primary-200/40"
      >
        <span
          class="font-serif text-[10px] tracking-[0.25em] text-primary-600 uppercase mb-4 block"
          >Padres de la Novia</span
        >
        <ul class="space-y-2">
          {
            brideParents.map((parent) => (
              <li class="font-serif text-base text-ink-800 font-medium leading-tight">
                {parent.nombre}
                {parent.finado && (
                  <span class="text-xs text-primary-600 font-sans ml-1" title="En memoria">†</span>
                )}
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Padres del Novio -->
      <div class="flex flex-col items-center p-3">
        <span
          class="font-serif text-[10px] tracking-[0.25em] text-primary-600 uppercase mb-4 block"
          >Padres del Novio</span
        >
        <ul class="space-y-2">
          {
            groomParents.map((parent) => (
              <li class="font-serif text-base text-ink-800 font-medium leading-tight">
                {parent.nombre}
                {parent.finado && (
                  <span class="text-xs text-primary-600 font-sans ml-1" title="En memoria">†</span>
                )}
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Divisor sutil -->
    <div class="w-16 h-px bg-primary-300 mx-auto my-8"></div>

    <!-- Padrinos -->
    <div class="flex flex-col items-center mt-6">
      <span
        class="font-serif text-[10px] tracking-[0.25em] text-primary-600 uppercase mb-4 block"
        >Nuestros Padrinos</span
      >
      <ul class="space-y-2">
        {
          godparents.map((godparent) => (
            <li class="font-serif text-base text-ink-800 font-medium leading-tight">
              {godparent.nombre}
              {godparent.finado && (
                <span class="text-xs text-primary-600 font-sans ml-1" title="En memoria">†</span>
              )}
            </li>
          ))
        }
      </ul>
      <p class="font-sans text-[10px] text-ink-500 italic mt-3">
        Padrinos de Velación
      </p>
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove("opacity-0", "translate-y-8");
            entry.target.classList.add("opacity-100", "translate-y-0");
          }
        });
      },
      { threshold: 0.15 },
    );

    const target = document.getElementById("accompanied-section");
    if (target) observer.observe(target);
  });
</script>
