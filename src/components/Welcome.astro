---
interface Props {
  groomName: string;
  brideName: string;
  weddingDate?: string;
  weddingDateLabel: string;
  heroImage: string;
  heroSubtitle?: string;
}

const {
  groomName,
  brideName,
  weddingDateLabel,
  heroImage,
  heroSubtitle = 'Nos casamos',
} = Astro.props;
---

<section
  id="hero-section"
  class="relative min-h-screen overflow-hidden bg-ink-900"
>
  <!-- Contenedor Fijo: Se queda quieto -->
  <div id="hero-fixed-container" class="absolute inset-0 z-0 h-screen w-full">
    <img
      id="hero-bg"
      src={heroImage}
      alt="Foto de la pareja"
      class="w-full h-full object-cover object-center scale-110 opacity-0"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-ink-900/30 via-ink-900/10 to-ink-900/80"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-ink-900/60 via-transparent to-transparent"></div>
  </div>

  <!-- Contenedor Móvil: Este sube con el scroll -->
  <div id="hero-content" class="relative z-10 min-h-screen flex flex-col items-center justify-end pb-20 px-10 w-full text-center text-surface-50">
    
    <!-- Tus elementos de texto (brideName, groomName, etc.) se mantienen igual -->
    <div class="hero-element opacity-0 flex items-center justify-center gap-2 mb-6">
       <!-- ... tu SVG y adornos ... -->
    </div>

    <p class="hero-element opacity-0 font-sans tracking-[0.35em] text-[10px] uppercase mb-5 text-primary-200 font-light">
      {heroSubtitle}
    </p>

    <h1 class="font-script text-7xl leading-none mb-6 drop-shadow-2xl">
      <span class="hero-element opacity-0 block text-surface-50">{brideName}</span>
      <span class="hero-element opacity-0 block text-3xl font-sans font-light tracking-[0.4em] text-primary-300 my-3">&</span>
      <span class="hero-element opacity-0 block text-surface-50">{groomName}</span>
    </h1>

    <p class="hero-element opacity-0 font-serif text-lg tracking-wide font-light text-surface-100">
      {weddingDateLabel}
    </p>

    <!-- Indicador de Scroll -->
    <div class="hero-scroll opacity-0 mt-12 flex flex-col items-center gap-2 text-surface-100/70">
       <!-- ... tu SVG de flecha ... -->
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    
    // 1. Animación de entrada (Timeline inicial)
    const tl = gsap.timeline();

    tl.to("#hero-bg", {
      opacity: 1,
      scale: 1,
      duration: 2.5,
      ease: "power2.out"
    })
    .to(".hero-element", {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15, 
      ease: "power3.out"
    }, "-=1.5") 
    .to(".hero-scroll", {
      opacity: 1,
      duration: 1
    }, "-=0.5");

    // 2. Efecto de "Fixed" y desaparición de texto
    // Bloqueamos la sección para que no se mueva
    ScrollTrigger.create({
      trigger: "#hero-section",
      start: "top top",
      end: "bottom top",
      pin: true,           // Mantiene la sección quieta
      pinSpacing: false,   // Permite que la siguiente sección suba encima
    });

    // 3. Animamos el contenido de texto hacia arriba y desapareciendo
    gsap.to("#hero-content", {
      y: -150,
      opacity: 0,
      ease: "none",
      scrollTrigger: {
        trigger: "#hero-section",
        start: "top top",
        end: "bottom 40%", // Termina de desaparecer antes de que acabe la sección
        scrub: true
      }
    });

    // Opcional: Un ligero zoom out a la imagen mientras haces scroll
    gsap.to("#hero-bg", {
      scale: 1.1,
      ease: "none",
      scrollTrigger: {
        trigger: "#hero-section",
        start: "top top",
        end: "bottom top",
        scrub: true
      }
    });
  });
</script>