---
interface Props {
  message: string;
  author?: string; // Opcional, por si es una cita
}

const { message, author } = Astro.props;
---

<section class="w-full bg-primary-300">
  <div
    id="message-container"
    class="w-full mx-auto relative opacity-0 translate-y-10"
  >
    <div
      class="w-full message-card bg-primary-300 border border-primary-400 p-4 md:p-8 text-center shadow-sm relative z-10"
    >
      <div class="w-12 h-px bg-primary-300 mx-auto mb-8 decoration-line"></div>

      <p
        id="message-text"
        class="text-sm md:text-xl font-serif italic text-ink-900 leading-relaxed"
      >
        {message}
      </p>

      {
        author && (
          <p class="mt-6 font-sans tracking-[0.2em] text-xs uppercase text-primary-400 font-medium">
            — {author}
          </p>
        )
      }

      <div class="w-12 h-px bg-primary-300 mx-auto mt-8 decoration-line"></div>
    </div>

    <div
      class="absolute -z-10 top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-primary-100/30 blur-3xl rounded-full"
    >
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector("#message-container");
    const text = document.querySelector("#message-text");
    const lines = document.querySelectorAll(".decoration-line");

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: container,
        start: "top 85%", // Comienza cuando el tope del div llega al 85% del viewport
        toggleActions: "play none none reverse", // Se reproduce al bajar, se revierte al subir
      },
    });

    tl.to(container, {
      opacity: 1,
      y: 0,
      duration: 1.2,
      ease: "power4.out",
    })
      .from(
        text,
        {
          opacity: 0,
          scale: 0.95,
          duration: 1,
          ease: "power2.out",
        },
        "-=0.8",
      )
      .from(
        lines,
        {
          width: 0,
          opacity: 0,
          duration: 0.8,
          stagger: 0.2,
          ease: "expo.out",
        },
        "-=0.5",
      );
  });
</script>

<style>
  /* Fuente Serif para mensajes elegantes */
  @import url("https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;1,400&display=swap");

  .font-serif {
    font-family: "Playfair Display", serif;
  }
</style>
