---

<section
  class="w-full bg-accent-blue-50/40 py-20 px-6 border-b border-primary-200/50 flex flex-col items-center"
>
  <div
    id="dresscode-section"
    class="max-w-2xl w-full mx-auto opacity-0 translate-y-8 transition-all duration-1000 ease-out text-center"
  >
    <div class="mb-4 text-accent-blue-500 flex justify-center">
      <Fragment set:html={icons.default} />
    </div>

    <span
      class="font-sans text-[10px] uppercase tracking-[0.3em] text-accent-blue-600 font-semibold mb-2 block"
    >
      Capítulo IV
    </span>
    <h2 class="font-serif text-3xl text-ink-800 font-light mb-2">
      Código de Vestimenta
    </h2>
    <div
      class="inline-flex items-center justify-center px-4 py-1.5 bg-accent-blue-100/50 rounded-full mb-10 border border-accent-blue-200"
    >
      <p
        class="font-serif text-lg text-accent-blue-800 font-medium tracking-wide"
      >
        {activeTitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full mb-14">
      {
        activeCategories.map((cat) => (
          <div class="bg-white p-8 rounded-2xl border border-accent-blue-100 shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_8px_30px_-10px_rgba(0,0,0,0.08)] hover:border-accent-blue-300 flex flex-col items-center text-center group">
            {cat.iconType && (
              <div class="mb-4 text-accent-blue-400 p-4 bg-accent-blue-50/50 rounded-full group-hover:scale-110 group-hover:text-accent-blue-500 group-hover:bg-accent-blue-100/50 transition-all duration-300">
                <Fragment set:html={icons[cat.iconType] || icons.default} />
              </div>
            )}

            <h3 class="font-serif text-xl text-ink-800 font-medium mb-3">
              {cat.title}
            </h3>
            <p class="font-sans text-[13px] md:text-sm text-ink-600 leading-relaxed font-light">
              {cat.description}
            </p>
          </div>
        ))
      }
    </div>

    {
      reservedColors && reservedColors.length > 0 && (
        <div class="flex flex-col items-center bg-surface-50/80 p-8 rounded-2xl border border-primary-100/50">
          <h3 class="font-serif text-lg text-ink-800 font-medium mb-3">
            Colores Reservados
          </h3>
          <p class="font-sans text-xs text-ink-500 mb-6 max-w-sm leading-relaxed">
            Agradecemos su comprensión al{" "}
            <strong>evitar vestir estos colores</strong> para permitir que la
            novia destaque en su día especial.
          </p>

          <div class="flex flex-wrap justify-center gap-8">
            {reservedColors.map((color) => (
              <div class="flex flex-col items-center gap-3 group">
                <div
                  class="w-14 h-14 rounded-full border border-ink-900/10 shadow-sm relative flex items-center justify-center overflow-hidden transition-all duration-300 group-hover:scale-110 group-hover:shadow-md"
                  style={`background-color: ${color.hex};`}
                >
                  <div class="absolute w-[150%] h-[1.5px] bg-ink-800/40 rotate-45 pointer-events-none mix-blend-multiply" />
                </div>
                <span class="font-sans text-[10px] uppercase tracking-widest text-ink-600 font-medium group-hover:text-ink-900 transition-colors">
                  {color.name}
                </span>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove("opacity-0", "translate-y-8");
            entry.target.classList.add("opacity-100", "translate-y-0");
          }
        });
      },
      { threshold: 0.15 },
    );

    const target = document.getElementById("dresscode-section");
    if (target) observer.observe(target);
  });
</script>
