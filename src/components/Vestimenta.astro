---
// 1. Definición de Tipos
type DressCodeLevel = "formal" | "semiformal" | "casual" | "custom";

interface DressCategory {
  title: string;
  description: string;
  iconType?: "dress" | "suit" | "default";
}

interface ReservedColor {
  hex: string;
  name: string;
}

interface Props {
  level?: DressCodeLevel;
  customTitle?: string;
  customCategories?: DressCategory[];
  reservedColors?: ReservedColor[];
}

// 2. Diccionario de Presets (Escalabilidad)
const PRESETS = {
  formal: {
    title: "Rigurosa Etiqueta",
    categories: [
      {
        title: "Ellas",
        description:
          "Vestido largo de noche elegante. Tonos sobrios o de gala.",
        iconType: "dress" as const,
      },
      {
        title: "Ellos",
        description:
          "Esmoquin o traje oscuro formal. Camisa de vestir, corbata o moño.",
        iconType: "suit" as const,
      },
    ],
  },
  semiformal: {
    title: "Semi Formal / Cóctel",
    categories: [
      {
        title: "Ellas",
        description:
          "Vestido de cóctel (midi o hasta la rodilla) o conjunto elegante de pantalón.",
        iconType: "dress" as const,
      },
      {
        title: "Ellos",
        description:
          "Traje claro u oscuro, camisa de vestir. La corbata es opcional.",
        iconType: "suit" as const,
      },
    ],
  },
  casual: {
    title: "Casual Elegante",
    categories: [
      {
        title: "Ellas",
        description:
          "Vestido ligero de día, maxivestido o conjunto fresco. Evitar mezclilla.",
        iconType: "dress" as const,
      },
      {
        title: "Ellos",
        description:
          "Pantalón de lino o caqui, camisa fresca, guayabera y mocasines.",
        iconType: "suit" as const,
      },
    ],
  },
};

// 3. Extracción de Props y Lógica de Renderizado
const {
  level = "semiformal", // Valor por defecto
  customTitle,
  customCategories,
  reservedColors = [{ hex: "#FFFFFF", name: "Blanco" }],
} = Astro.props;

// Resolviendo qué datos mostrar basados en el "level"
const isCustom = level === "custom";
const activeTitle =
  isCustom && customTitle
    ? customTitle
    : PRESETS[level !== "custom" ? level : "semiformal"].title;
const activeCategories =
  isCustom && customCategories
    ? customCategories
    : PRESETS[level !== "custom" ? level : "semiformal"].categories;

// 4. Iconos Rediseñados (Minimalistas y Premium, stroke 1.25)
const icons: Record<string, string> = {
  // Vestido femenino elegante
