---
// 1. Ampliamos la interfaz para incluir un subtítulo y el tipo de ícono
interface LocationDetails {
  title: string;
  subtitle?: string;
  name?: string;
  time: string;
  address: string;
  googleMapsUrl?: string;
  wazeUrl?: string;
  iconType?: "ceremony" | "reception" | "party" | "civil";
}

interface Props {
  locations?: LocationDetails[];
}

// 2. Definimos un arreglo por defecto en lugar de constantes separadas
const defaultLocations: LocationDetails[] = [
  {
    title: "Ceremonia Religiosa",
    subtitle: '"Sí, acepto"',
    name: "Cuasiparroquia de nuestra señora de Guadalupe",
    time: "17:00 Hrs",
    address: "Manzana 004, Americas I, 56610 Valle de Chalco Solidaridad, Méx.",
    googleMapsUrl: "https://maps.app.goo.gl/j5ePjMXsFVXJZXcQ7",
    iconType: "ceremony",
  },
  {
    title: "Recepción",
    subtitle: '"A celebrar"',
    time: "18:00 Hrs",
    address: "Andador Pablo Galeana mz 40 lt 13 2 sección",
    iconType: "reception",
  },
];

const { locations = defaultLocations } = Astro.props;

// 3. Diccionario de íconos SVG para inyectarlos dinámicamente
const icons: Record<string, string> = {
  // Capilla minimalista con cruz y puerta arqueada
  ceremony: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-10 h-10">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M10 21v-4a2 2 0 0 1 4 0v4M10 5h4M12 3v5M6 21v-7l6-6 6 6v7" />
  </svg>`,

  // Cubiertos (Tenedor y cuchillo) de banquete, un clásico elegante
  reception: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-10 h-10">
    <path stroke-linecap="round" stroke-linejoin="round" d="M19 3v12h-5c-.02-3.68.18-7.41 5-12zM19 15v6h-1v-3M9 3v17M6 3v3a3 3 0 1 0 6 0V3" />
  </svg>`,

  // Acta de matrimonio con doblez en la esquina, sello de cera y listón
  civil: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-10 h-10">
    <path stroke-linecap="round" stroke-linejoin="round" d="M14 3v4a1 1 0 0 0 1 1h4M5 8V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2h-5M6 14a3 3 0 1 0 0 6 3 3 0 0 0 0-6Zm-1.5 5.5-1.5 4.5 3-1.5 3 1.5-1.5-4.5" />
  </svg>`,

  // Pin de ubicación estilizado con círculo interior suave
  default: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.25" stroke="currentColor" class="w-10 h-10">
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0Z" />
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 13a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" />
  </svg>`,
};
---

<section
  class="w-full bg-surface-100 py-20 px-6 border-b border-primary-200/50 flex flex-col items-center"
>
  <div
    id="locations-section"
    class="max-w-md w-full mx-auto opacity-0 translate-y-8 transition-all duration-1000 ease-out text-center"
  >
    <div class="mb-12">
      <span
        class="font-sans text-[10px] uppercase tracking-[0.3em] text-primary-600 font-semibold mb-2 block"
      >
        Capítulo III
      </span>
      <h2 class="font-serif text-3xl text-ink-800 font-light mb-4">
        Lugares y Horarios
      </h2>
      <p class="font-sans text-xs text-ink-500 italic">
        Cada momento ha sido cuidadosamente planeado para celebrar nuestro amor.
      </p>
    </div>

    <div class="space-y-12">
      {
        locations.map((loc) => (
          <div class="bg-surface-50 border border-primary-300 p-8 rounded-lg shadow-sm relative overflow-hidden paper-card group">
            <div class="absolute top-2 left-2 w-6 h-6 border-t border-l border-primary-300 transition-colors group-hover:border-primary-400" />
            <div class="absolute top-2 right-2 w-6 h-6 border-t border-r border-primary-300 transition-colors group-hover:border-primary-400" />
            <div class="absolute bottom-2 left-2 w-6 h-6 border-b border-l border-primary-300 transition-colors group-hover:border-primary-400" />
            <div class="absolute bottom-2 right-2 w-6 h-6 border-b border-r border-primary-300 transition-colors group-hover:border-primary-400" />

            <div class="text-primary-500 mb-4 flex justify-center">
              <Fragment set:html={icons[loc.iconType || "default"]} />
            </div>

            <h3 class="font-serif text-2xl text-ink-800 font-medium mb-1">
              {loc.title}
            </h3>

            {loc.subtitle && (
              <span class="font-sans text-[10px] uppercase tracking-widest text-primary-600 font-semibold mb-4 block">
                {loc.subtitle}
              </span>
            )}

            {loc.name && (
              <p class="font-serif text-lg text-ink-900 font-semibold mb-2">
                {loc.name}
              </p>
            )}

            <p class="font-serif text-base text-primary-800 italic mb-3">
              {loc.time}
            </p>

            <p class="font-sans text-xs text-ink-700 leading-relaxed mb-6 max-w-[280px] mx-auto font-light">
              {loc.address}
            </p>

            <div class="flex flex-wrap gap-3 justify-center">
              {loc.googleMapsUrl && (
                <a
                  href={loc.googleMapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-4 py-2 border border-primary-400 rounded-md font-sans text-xs uppercase tracking-wider text-ink-800 hover:bg-primary-100/50 active:scale-95 transition-all duration-300 shadow-sm"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    class="w-3.5 h-3.5 text-primary-600"
                  >
                    <path
                      fill-rule="evenodd"
                      d="m9.69 18.933.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.343 7.587.829.799 1.655 1.381 2.274 1.765.31.193.57.337.757.433.151.078.256.129.282.14l.006.003ZM10 12a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  Google Maps
                </a>
              )}

              {loc.wazeUrl && (
                <a
                  href={loc.wazeUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center gap-1.5 px-4 py-2 border border-primary-400 rounded-md font-sans text-xs uppercase tracking-wider text-ink-800 hover:bg-primary-100/50 active:scale-95 transition-all duration-300 shadow-sm"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="w-3.5 h-3.5 text-accent-blue-500"
                  >
                    <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 14.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5-1.5-.67-1.5-1.5zm-5-3c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5-1.5-.67-1.5-1.5zm4.5-5.5c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3z" />
                  </svg>
                  Waze
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove("opacity-0", "translate-y-8");
            entry.target.classList.add("opacity-100", "translate-y-0");
          }
        });
      },
      { threshold: 0.15 },
    );

    const target = document.getElementById("locations-section");
    if (target) observer.observe(target);
  });
</script>

<style>
  /* Efecto textura de papel artesanal */
  .paper-card {
    background-image:
      radial-gradient(rgba(0, 0, 0, 0.015) 1px, transparent 0),
      radial-gradient(rgba(0, 0, 0, 0.01) 1px, transparent 0);
    background-size: 8px 8px;
    background-position:
      0 0,
      4px 4px;
  }
</style>
